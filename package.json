{
	"name": "meowlish-server",
	"version": "0.0.1",
	"description": "",
	"author": "D-ng7721",
	"private": true,
	"license": "UNLICENSED",
	"scripts": {
		"build": "nest build --builder swc",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"start": "node --env-file=.env.production.local dist/main",
		"start:dev": "nest start --env-file=.env.development.local --watch --builder swc",
		"start:debug": "nest start --env-file=.env.development.local --debug --watch --builder swc",
		"start:prod": "node dist/main",
		"docker:db:dev": "docker compose -f docker-compose.db.yaml --env-file .env.development.local up -d",
		"docker:api:dev": "",
		"docker:api:prod": "",
		"prisma:migrate:dev": "dotenv -e .env.development.local npx prisma migrate dev",
		"prisma:migrate:prod": "dotenv -e .env.production.local npx prisma migrate deploy",
		"lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "jest --config ./test/jest-e2e.json",
		"prepare": "node -e \"if (process.env.NODE_ENV !== 'production'){process.exit(1)} \" || husky install"
	},
	"dependencies": {
		"@casl/ability": "^6.7.3",
		"@nestjs/axios": "^4.0.0",
		"@nestjs/common": "^11.1.3",
		"@nestjs/config": "^4.0.2",
		"@nestjs/core": "^11.0.1",
		"@nestjs/event-emitter": "^3.0.1",
		"@nestjs/jwt": "^11.0.0",
		"@nestjs/mapped-types": "^2.1.0",
		"@nestjs/passport": "^11.0.5",
		"@nestjs/platform-express": "^11.0.1",
		"@nestjs/swagger": "^11.2.0",
		"@nestjs/throttler": "^6.4.0",
		"@prisma/client": "^6.17.1",
		"axios": "^1.10.0",
		"bcrypt": "^6.0.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.2",
		"cross-env": "^7.0.3",
		"dotenv-cli": "^10.0.0",
		"nest-winston": "^1.10.2",
		"nestjs-form-data": "^1.9.93",
		"nestjs-i18n": "^10.5.1",
		"nestjs-request-context": "^4.0.0",
		"passport": "^0.7.0",
		"passport-google-oauth20": "^2.0.0",
		"passport-jwt": "^4.0.1",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"swagger-ui-express": "^5.0.1",
		"winston": "^3.17.0",
		"zod": "^3.25.67"
	},
	"devDependencies": {
		"@darraghor/eslint-plugin-nestjs-typed": "^6.7.0",
		"@eslint/eslintrc": "^3.2.0",
		"@eslint/js": "^9.30.0",
		"@nestjs/cli": "^11.0.0",
		"@nestjs/schematics": "^11.0.0",
		"@nestjs/testing": "^11.0.1",
		"@swc/cli": "^0.6.0",
		"@swc/core": "^1.12.1",
		"@trivago/prettier-plugin-sort-imports": "^5.2.2",
		"@types/bcrypt": "^5.0.2",
		"@types/express": "^5.0.0",
		"@types/jest": "^29.5.14",
		"@types/node": "^22.10.7",
		"@types/passport-google-oauth20": "^2.0.16",
		"@types/passport-jwt": "^4.0.1",
		"@types/passport-local": "^1.0.38",
		"@types/supertest": "^6.0.2",
		"@types/swagger-ui-express": "^4.1.8",
		"@typescript-eslint/parser": "^8.35.0",
		"eslint": "^9.30.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-perfectionist": "^4.15.0",
		"eslint-plugin-prettier": "^5.2.2",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"globals": "^16.0.0",
		"husky": "^9.1.7",
		"jest": "^29.7.0",
		"lint-staged": "^16.1.2",
		"prettier": "^3.4.2",
		"prisma": "^6.16.3",
		"source-map-support": "^0.5.21",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.35.1"
	},
	"jest": {
		"preset": "ts-jest",
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node",
		"moduleNameMapper": {
			"^@app/(.*)$": "<rootDir>/app/$1",
			"^@common/(.*)$": "<rootDir>/common/$1",
			"^@configs/(.*)$": "<rootDir>/configs/$1",
			"^@languages/(.*)$": "<rootDir>/languages/$1",
			"^@modules/(.*)$": "<rootDir>/modules/$1",
			"^@router/(.*)$": "<rootDir>/router/$1",
			"^@app$": "<rootDir>/app",
			"^@common$": "<rootDir>/common",
			"^@configs$": "<rootDir>/configs",
			"^@languages$": "<rootDir>/languages",
			"^@modules$": "<rootDir>/modules",
			"^@router$": "<rootDir>/router"
		}
	},
	"lint-staged": {
		"*.{js,ts}": [
			"prettier --write",
			"eslint --fix"
		]
	}
}
