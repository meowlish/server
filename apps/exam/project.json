{
	"name": "exam",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "apps/exam/src",
	"projectType": "application",
	"tags": [],
	"targets": {
		"prisma:generate": {
			"executor": "nx:run-commands",
			"cache": true,
			"options": {
				"command": "pnpm exec prisma generate",
				"cwd": "apps/exam"
			},
			"inputs": ["{projectRoot}/prisma"],
			"outputs": ["{workspaceRoot}/node_modules/.prisma/client/exam"]
		},
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"command": "webpack-cli build",
				"args": ["--node-env=production"],
				"cwd": "apps/exam"
			},
			"cache": true,
			"configurations": {
				"development": {
					"args": ["--node-env=development"]
				}
			},
			"dependsOn": ["prisma:generate"]
		},
		"prune-lockfile": {
			"dependsOn": ["build"],
			"cache": true,
			"executor": "@nx/js:prune-lockfile",
			"outputs": [
				"{workspaceRoot}/dist/apps/exam/package.json",
				"{workspaceRoot}/dist/apps/exam/pnpm-lock.yaml"
			],
			"options": {
				"buildTarget": "build"
			}
		},
		"copy-workspace-modules": {
			"dependsOn": ["build"],
			"cache": true,
			"outputs": ["{workspaceRoot}/dist/apps/exam/workspace_modules"],
			"executor": "@nx/js:copy-workspace-modules",
			"options": {
				"buildTarget": "build"
			}
		},
		"prune": {
			"dependsOn": ["prune-lockfile", "copy-workspace-modules"],
			"executor": "nx:noop"
		},
		"serve": {
			"continuous": true,
			"executor": "@nx/js:node",
			"defaultConfiguration": "development",
			"dependsOn": ["build"],
			"options": {
				"buildTarget": "exam:build",
				"runBuildTargetDependencies": false
			},
			"configurations": {
				"development": {
					"buildTarget": "exam:build:development"
				},
				"production": {
					"buildTarget": "exam:build:production"
				}
			}
		},
		"test": {
			"options": {
				"passWithNoTests": true
			}
		}
	}
}
