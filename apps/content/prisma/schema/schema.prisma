generator client {
  provider = "prisma-client-js"
  output   = "../../../../node_modules/.prisma/client/content"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Blog {
  id        String   @id @default(uuid())
  title     String
  content   String
  authorId  String   @map("author_id")
  tags      String[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("blogs")
}

model FlashCard {
  id            String   @id @default(uuid())
  word          String
  definition    String
  image         String?
  partOfSpeech  String?  @map("part_of_speech")
  pronunciation String?
  examples      String[]
  notes         String?
  authorId      String   @map("author_id")
  tags          String[]
  listId        String   @map("list_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  list FlashCardList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
  @@map("flash_cards")
}

model FlashCardList {
  id          String   @id @default(uuid())
  name        String
  description String?
  authorId    String   @map("author_id")
  isPublic    Boolean  @default(false) @map("is_public")
  tags        String[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cards FlashCard[]

  @@map("flash_card_lists")
}
